{
  "name": "anetd-webui",
  "version": "0.1.0",
  "private": true,
  "description": "WebUI for anetd Android network rules daemon",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:wasm": "make -C src/wasm",
    "build": "npm run build:wasm && vite build",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "svelte": "^5.44.1",
    "svelte-check": "^4.7.2",
    "typescript": "^5.8.3",
    "vite": "^7.1.4"
  }
}
